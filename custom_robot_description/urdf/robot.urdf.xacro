<?xml version="1.0" ?>
<robot name="independent_robot" xmlns:xacro="http://ros.org/wiki/xacro">

  <xacro:property name="base_radius" value="0.14"/>
  <xacro:property name="base_length" value="0.18"/>
  <xacro:property name="base_mass"   value="2.5"/>

  <xacro:property name="wheel_radius" value="0.035"/>
  <xacro:property name="wheel_length" value="0.02"/>
  <xacro:property name="wheel_mass"   value="0.2"/>
  <xacro:property name="wheel_track"  value="0.23"/>

  <link name="base_link">
    <visual>
      <origin xyz="0 0 ${base_length/2}" rpy="0 0 3.14159"/>
      <geometry>
        <cylinder radius="${base_radius}" length="${base_length}"/>
      </geometry>
      <material name="dark_grey">
        <color rgba="0.2 0.2 0.2 1.0"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 ${base_length/2}" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="${base_radius}" length="${base_length}"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 ${base_length/2}" rpy="0 0 0"/>
      <mass value="${base_mass}"/>
      <inertia ixx="0.0189" ixy="0.0" ixz="0.0" iyy="0.0189" iyz="0.0" izz="0.0245"/>
    </inertial>
  </link>

  <link name="drive_left_wheel">
    <visual>
      <geometry>
        <cylinder radius="${wheel_radius}" length="${wheel_length}"/>
      </geometry>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="${wheel_radius}" length="${wheel_length}"/>
      </geometry>
    </collision>
    <inertial>
    <mass value="${wheel_mass}"/>
    <inertia ixx="0.000067" ixy="0.0" ixz="0.0"
            iyy="0.000067" iyz="0.0"
            izz="0.00012"/>
    </inertial>
  </link>
  <joint name="drive_left_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="drive_left_wheel"/>
    <origin xyz="0 ${wheel_track/2} 0" rpy="-1.5708 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>


  <link name="drive_right_wheel">
    <visual>
      <geometry>
        <cylinder radius="${wheel_radius}" length="${wheel_length}"/>
      </geometry>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="${wheel_radius}" length="${wheel_length}"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="${wheel_mass}"/>
      <inertia ixx="0.000067" ixy="0.0" ixz="0.0"
              iyy="0.000067" iyz="0.0"
              izz="0.00012"/>
    </inertial>
  </link>

  <joint name="drive_right_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="drive_right_wheel"/>
    <origin xyz="0 -${wheel_track/2} 0" rpy="-1.5708 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>

  <link name="caster_wheel">
    <visual>
      <geometry>
        <sphere radius="${wheel_radius}"/>
      </geometry>
      <material name="light_grey">
        <color rgba="0.6 0.6 0.6 1.0"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <sphere radius="${wheel_radius}"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.1"/>
      <inertia ixx="0.00004" ixy="0.0" ixz="0.0" iyy="0.00004" iyz="0.0" izz="0.00004"/>
    </inertial>
  </link>

  <joint name="caster_joint" type="fixed">
    <parent link="base_link"/>
    <child link="caster_wheel"/>
    <origin xyz="0.09 0 0" rpy="0 0 0"/>
  </joint>

  <link name="front_caster">
    <visual>
      <geometry>
        <sphere radius="${wheel_radius}"/>
      </geometry>
      <material name="light_grey">
        <color rgba="0.6 0.6 0.6 1.0"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <sphere radius="${wheel_radius}"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.1"/>
      <inertia ixx="0.00004" ixy="0.0" ixz="0.0" iyy="0.00004" iyz="0.0" izz="0.00004"/>
    </inertial>
  </link>

  <joint name="front_caster_joint" type="fixed">
    <parent link="base_link"/>
    <child link="front_caster"/>
    <origin xyz="-0.09 0 0" rpy="0 0 0"/>
  </joint>

  <link name="laser_frame">
    <visual>
      <geometry>
        <cylinder radius="0.03" length="0.02"/>
      </geometry>
      <material name="blue">
        <color rgba="0.0 0.0 0.8 1.0"/>
      </material>
    </visual>
  </link>

  <joint name="laser_joint" type="fixed">
    <parent link="base_link"/>
    <child link="laser_frame"/>
    <origin xyz="0 0 ${base_length + 0.01}" rpy="0 0 0"/>
  </joint>

  <!-- ════════════════════════════════════════════════════════════
       OAK-D Pro style RGBD camera  (TurtleBot 4 based)
       Mounted on the front face of the cylinder body,
       roughly 2/3 of the way up.
       ════════════════════════════════════════════════════════════ -->

  <!-- Physical dimensions of the OAK-D Pro body -->
  <xacro:property name="cam_w"        value="0.097"/>   <!-- width  (Y) -->
  <xacro:property name="cam_h"        value="0.030"/>   <!-- height (Z) -->
  <xacro:property name="cam_d"        value="0.017"/>   <!-- depth  (X) -->
  <xacro:property name="cam_mass"     value="0.061"/>
  <xacro:property name="stereo_base"  value="0.075"/>   <!-- stereo baseline -->

  <!-- Mount position: front of cylinder, 2/3 up the body -->
  <xacro:property name="cam_x"  value="${base_radius}"/>        <!-- flush with front face -->
  <xacro:property name="cam_y"  value="0.0"/>
  <xacro:property name="cam_z"  value="${base_length * 0.66}"/> <!-- ~12 cm above base origin -->

  <!-- ── Camera body link ── -->
  <link name="oakd_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="${cam_d} ${cam_w} ${cam_h}"/>
      </geometry>
      <material name="oakd_black">
        <color rgba="0.1 0.1 0.1 1.0"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="${cam_d} ${cam_w} ${cam_h}"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="${cam_mass}"/>
      <inertia
        ixx="${cam_mass/12*(cam_h*cam_h + cam_d*cam_d)}"
        ixy="0" ixz="0"
        iyy="${cam_mass/12*(cam_w*cam_w + cam_d*cam_d)}"
        iyz="0"
        izz="${cam_mass/12*(cam_w*cam_w + cam_h*cam_h)}"/>
    </inertial>
  </link>

  <joint name="oakd_joint" type="fixed">
    <parent link="base_link"/>
    <child  link="oakd_link"/>
    <origin xyz="${cam_x} ${cam_y} ${cam_z}" rpy="0 0 0"/>
  </joint>

  <!-- ── RGB camera frame (forward-facing, ROS body convention) ── -->
  <link name="oakd_rgb_camera_frame"/>
  <joint name="oakd_rgb_camera_joint" type="fixed">
    <parent link="oakd_link"/>
    <child  link="oakd_rgb_camera_frame"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <!-- ── RGB optical frame (camera convention: Z forward, X right, Y down) ── -->
  <link name="oakd_rgb_camera_optical_frame"/>
  <joint name="oakd_rgb_camera_optical_joint" type="fixed">
    <parent link="oakd_rgb_camera_frame"/>
    <child  link="oakd_rgb_camera_optical_frame"/>
    <origin xyz="0 0 0" rpy="${-pi/2} 0 ${-pi/2}"/>
  </joint>

  <!-- ── Left stereo camera frame ── -->
  <link name="oakd_left_camera_frame"/>
  <joint name="oakd_left_camera_joint" type="fixed">
    <parent link="oakd_link"/>
    <child  link="oakd_left_camera_frame"/>
    <origin xyz="0 ${stereo_base/2} 0" rpy="0 0 0"/>
  </joint>

  <link name="oakd_left_camera_optical_frame"/>
  <joint name="oakd_left_camera_optical_joint" type="fixed">
    <parent link="oakd_left_camera_frame"/>
    <child  link="oakd_left_camera_optical_frame"/>
    <origin xyz="0 0 0" rpy="${-pi/2} 0 ${-pi/2}"/>
  </joint>

  <!-- ── Right stereo camera frame ── -->
  <link name="oakd_right_camera_frame"/>
  <joint name="oakd_right_camera_joint" type="fixed">
    <parent link="oakd_link"/>
    <child  link="oakd_right_camera_frame"/>
    <origin xyz="0 ${-stereo_base/2} 0" rpy="0 0 0"/>
  </joint>

  <link name="oakd_right_camera_optical_frame"/>
  <joint name="oakd_right_camera_optical_joint" type="fixed">
    <parent link="oakd_right_camera_frame"/>
    <child  link="oakd_right_camera_optical_frame"/>
    <origin xyz="0 0 0" rpy="${-pi/2} 0 ${-pi/2}"/>
  </joint>

  <!-- ── Gazebo rgbd_camera sensor ── -->
  <gazebo reference="oakd_rgb_camera_frame">
    <sensor name="rgbd_camera" type="rgbd_camera">
      <always_on>1</always_on>
      <update_rate>15</update_rate>
      <camera>
        <!-- 1.047 rad (60°) — use this instead of the nominal OAK-D 69° (1.204).
             Gazebo does not apply horizontal_fov correctly to camera_info
             at the wider value, causing depth/RGB misalignment. -->
        <horizontal_fov>1.047</horizontal_fov>
        <image>
          <width>640</width>
          <height>480</height>
          <format>RGB_INT8</format>
        </image>
        <clip>
          <near>0.19</near>
          <far>19.1</far>
        </clip>
        <depth_camera>
          <clip>
            <near>0.19</near>
            <far>19.1</far>
          </clip>
        </depth_camera>
        <noise>
          <type>gaussian</type>
          <mean>0.0</mean>
          <stddev>0.007</stddev>
        </noise>
      </camera>
      <topic>oakd</topic>
      <gz_frame_id>oakd_rgb_camera_optical_frame</gz_frame_id>
    </sensor>
  </gazebo>

  <gazebo reference="caster_wheel">
    <mu1>1.0</mu1>
    <mu2>1.0</mu2>
    <kp>1000000.0</kp>
    <kd>10.0</kd>
  </gazebo>

  <gazebo reference="front_caster">
    <mu1>1.0</mu1>
    <mu2>1.0</mu2>
    <kp>1000000.0</kp>
    <kd>10.0</kd>
  </gazebo>

  <gazebo reference="drive_left_wheel">
    <mu1>1.0</mu1>
    <mu2>1.0</mu2>
    <kp>1000000.0</kp>
    <kd>10.0</kd>
  </gazebo>

  <gazebo reference="drive_right_wheel">
    <mu1>1.0</mu1>
    <mu2>1.0</mu2>
    <kp>1000000.0</kp>
    <kd>10.0</kd>
  </gazebo>

  <gazebo>
    <plugin filename="gz-sim-diff-drive-system" name="gz::sim::systems::DiffDrive">
      <left_joint>drive_left_wheel_joint</left_joint>
      <right_joint>drive_right_wheel_joint</right_joint>
      <wheel_separation>${wheel_track}</wheel_separation>
      <wheel_radius>${wheel_radius}</wheel_radius>
      <topic>cmd_vel</topic>
    </plugin>

    <plugin filename="gz-sim-odometry-publisher-system" name="gz::sim::systems::OdometryPublisher">
      <odom_frame>odom</odom_frame>
      <robot_base_frame>base_link</robot_base_frame>
      <odom_publish_frequency>50</odom_publish_frequency>
      <odom_topic>/odom</odom_topic>
      <tf_topic>/tf</tf_topic>
      <dimensions>2</dimensions>
    </plugin>
  </gazebo>

  <gazebo>
    <plugin filename="gz-sim-joint-state-publisher-system" name="gz::sim::systems::JointStatePublisher">
      <topic>joint_states</topic>
    </plugin>
  </gazebo>

  <gazebo reference="laser_frame">
    <sensor name="gpu_lidar" type="gpu_lidar">
      <pose>0 0 0 0 0 0</pose>
      <update_rate>10</update_rate>
      <visualize>true</visualize>
      <topic>scan</topic>
      <gz_frame_id>laser_frame</gz_frame_id>
      <lidar>
        <scan>
          <horizontal>
            <samples>640</samples>
            <resolution>1</resolution>
            <min_angle>-3.141592</min_angle>
            <max_angle>3.141592</max_angle>
          </horizontal>
        </scan>
        <range>
          <min>0.08</min>
          <max>10.0</max>
        </range>
      </lidar>
      </sensor>
  </gazebo>

</robot>